# =============================================================================
# AI Voice Assistant — Environment Configuration
# Copy this file to .env and fill in your API keys.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Selection
# Options: deepseek | openai | anthropic | google | local
# -----------------------------------------------------------------------------
LLM_PROVIDER=deepseek

# -----------------------------------------------------------------------------
# API Keys — fill in the key for the provider you intend to use
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# DeepSeek model preferences (optional overrides)
# -----------------------------------------------------------------------------
# DEEPSEEK_PREFERRED_CHAT_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# -----------------------------------------------------------------------------
# Anthropic / Claude model preferences (optional overrides)
# -----------------------------------------------------------------------------
# CLAUDE_PREFERRED_CHAT_MODEL=claude-opus-4-5-20251101
# CLAUDE_PREFERRED_TOOL_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Google Gemini model preferences (optional overrides)
# -----------------------------------------------------------------------------
# GEMINI_PREFERRED_CHAT_MODEL=gemini-1.5-flash

# -----------------------------------------------------------------------------
# Local LLM (LM Studio / llama.cpp) settings
# -----------------------------------------------------------------------------
# LOCAL_LLM_BASE_URL=http://localhost:1234/v1
# LOCAL_LLM_API_KEY=lm-studio
# LOCAL_LLM_MODEL=local-model

# GGUF model path for llama.cpp direct loading
# OLLAMA_CPP_MODEL_PATH=models/Qwen2.5-VL-7B-Instruct-IQ4_XS.gguf
# OLLAMA_CPP_N_GPU_LAYERS=-1
# OLLAMA_CPP_CONTEXT_SIZE=2048

# -----------------------------------------------------------------------------
# TTS Settings
# -----------------------------------------------------------------------------
# ASSISTANT_TTS_PROVIDER=kokoro
# KOKORO_VOICE=af_sarah
# KOKORO_LANGUAGE=en-us
# KOKORO_SPEED=1.0

# -----------------------------------------------------------------------------
# RAG Settings
# -----------------------------------------------------------------------------
ASSISTANT_RAG_ENABLED=true
RAG_DOCUMENTS_DIR=./documents
RAG_VECTOR_DB_DIR=./vector_db
RAG_NUM_RETRIEVED=5
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
# Disabled by default: RAGCare-QA showed lower Recall@5 and higher latency after BGE reranking.
RAG_ENABLE_RERANKER=false

# -----------------------------------------------------------------------------
# Tool / Agent Settings
# -----------------------------------------------------------------------------
# ASSISTANT_DISABLE_TOOLS=false
# ASSISTANT_SIMPLE_TOOLS=false

# -----------------------------------------------------------------------------
# Whisper STT language
# -----------------------------------------------------------------------------
# WHISPER_LANGUAGE=en
